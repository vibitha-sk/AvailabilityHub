# Azure Entra ID App Registration
REACT_APP_AZURE_CLIENT_ID=your-client-id-here
REACT_APP_AZURE_TENANT_ID=your-tenant-id-here
REACT_APP_REDIRECT_URI=http://localhost:3000

# API scope exposed by your Azure Function backend
REACT_APP_API_SCOPE=api://your-client-id-here/access_as_user

# Azure Function App base URL (no trailing slash)
REACT_APP_API_BASE_URL=https://your-function-app.azurewebsites.net/api
